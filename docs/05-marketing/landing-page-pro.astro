                </div>
                <div class="fade-in" style="animation-delay: 0.2s;">
                    <div class="text-5xl font-bold gradient-text stat-number">4.9/5</div>
                    <div class="text-gray-600 mt-2">User Rating</div>
                </div>
                <div class="fade-in" style="animation-delay: 0.3s;">
                    <div class="text-5xl font-bold gradient-text stat-number">127%</div>
                    <div class="text-gray-600 mt-2">Success Rate Increase</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Section Header -->
            <div class="text-center mb-16">
